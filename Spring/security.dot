		FormLoginConfigurer [label = "{<f0>FormLoginConfigurer&lt;H extends HttpSecurityBuilder&lt;H&gt;&gt;||<f2>&#186; init() : B\l&#186; loginPage(String) : T\l}", style = "rounded, filled", fillcolor = "springgreen"];
