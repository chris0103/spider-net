		ChannelSecurityConfigurer [label = "{<f0>ChannelSecurityConfigurer&lt;H extends HttpSecurityBuilder&lt;H&gt;&gt;|||{{<f30>ChannelRequestMatcherRegistry|<f31>|<f32>+ and() : H\l}}|{{<f40>RequiresChannelUrl|<f41>+ requestMatchers : List&lt;RequestMatcher&gt;\l|<f42>+ requiresInsecure() : ChannelRequestMatcherRegistry\l+ requiresSecure() : ChannelRequestMatcherRegistry\l}}}", style = "rounded, filled", fillcolor = "springgreen"];
