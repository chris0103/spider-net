	*/
	
	// Implementation -> Interface [arrowhead = "empty"];
	// Subclass -> Class;	
	// Referer -> Referee [arrowhead = "vee"];
	// Implementation -> InterfaceMinor [arrowhead = "odot"];
	
	/** application context **/
	ApplicationContext -> EnvironmentCapable;
	ApplicationContext -> ListableBeanFactory;
	ApplicationContext -> HierarchicalBeanFactory;
	ApplicationContext -> MessageSource;
	ApplicationContext -> ApplicationEventPublisher;
	ApplicationContext -> ResourcePatternResolver;
	ResourcePatternResolver -> ResourceLoader;
	ConfigurableApplicationContext -> ApplicationContext;
	ConfigurableApplicationContext:f2 -> ConfigurableListableBeanFactory [arrowhead = "vee"];
	ConfigurableListableBeanFactory -> ListableBeanFactory;	
	AbstractApplicationContext -> ConfigurableApplicationContext [arrowhead = "empty"];
	GenericApplicationContext -> AbstractApplicationContext;
	GenericApplicationContext -> BeanDefinitionRegistry [arrowhead = "empty"];
	AnnotationConfigApplicationContext -> GenericApplicationContext;
	AbstractRefreshableApplicationContext -> AbstractApplicationContext;
	AbstractRefreshableApplicationContext:f1 -> DefaultListableBeanFactory [arrowhead = "vee"];
	DefaultListableBeanFactory -> ConfigurableListableBeanFactory [arrowhead = "empty"];
	DefaultListableBeanFactory -> BeanDefinitionRegistry [arrowhead = "empty"];
	AbstractRefreshableConfigApplicationContext -> AbstractRefreshableApplicationContext;
	AbstractXmlApplicationContext -> AbstractRefreshableConfigApplicationContext;
	AbstractXmlApplicationContext:f2 -> XmlBeanDefinitionReader [arrowhead = "vee"];
	ClassPathXmlApplicationContext -> AbstractXmlApplicationContext;
	FileSystemXmlApplicationContext -> AbstractXmlApplicationContext;
	
	/** property resolver **/
	AbstractApplicationContext:f1 -> StandardEnvironment [arrowhead = "vee"];
	StandardEnvironment -> AbstractEnvironment;
	AbstractEnvironment -> ConfigurableEnvironment [arrowhead = "empty"];
	ConfigurableEnvironment -> ConfigurablePropertyResolver;
	ConfigurablePropertyResolver -> PropertyResolver;
	
	/** resource resolver **/
	AbstractApplicationContext:f1 -> PathMatchingResourcePatternResolver [arrowhead = "vee"];
	PathMatchingResourcePatternResolver -> ResourcePatternResolver [arrowhead = "empty"];
	PathMatchingResourcePatternResolver:f1 -> AbstractApplicationContext [arrowhead = "vee"];
	AbstractApplicationContext -> DefaultResourceLoader;
	DefaultResourceLoader -> ResourceLoader [arrowhead = "empty"];
	
	/** lifecyle **/
	AbstractApplicationContext:f1 -> DefaultLifecycleProcessor [arrowhead = "vee"];
	DefaultLifecycleProcessor:f1 -> ConfigurableListableBeanFactory [arrowhead = "vee"];
	DefaultLifecycleProcessor -> LifecycleProcessor [arrowhead = "empty"];
	LifecycleProcessor -> Lifecycle;
	
	/** placeholder configurer **/
	PropertySourcesPlaceholderConfigurer -> PlaceholderConfigurerSupport;
	PlaceholderConfigurerSupport -> PropertyResourceConfigurer;
	PropertyResourceConfigurer -> PropertiesLoaderSupport;
	PropertyPlaceholderConfigurer -> PlaceholderConfigurerSupport;
	PropertySourcesPlaceholderConfigurer:f1 -> PropertySources [arrowhead = "vee"];
	MutablePropertySources -> PropertySources [arrowhead = "empty"];
	PropertySourcesPlaceholderConfigurer:f1 -> MutablePropertySources [arrowhead = "vee"];
	PropertySourcesPlaceholderConfigurer:f2 -> ConfigurablePropertyResolver [arrowhead = "vee"];
	
	/** message sources **/
	HierarchicalMessageSource -> MessageSource;
	AbstractMessageSource -> HierarchicalMessageSource [arrowhead = "empty"];
	AbstractMessageSource -> MessageSourceSupport;
	
	/** name generator **/
	AnnotationBeanNameGenerator -> BeanNameGenerator [arrowhead = "empty"];
	
	// scope resolver
	AnnotationScopeMetadataResolver -> ScopeMetadataResolver [arrowhead = "empty"];
	Jsr330ScopeMetadataResolver -> ScopeMetadataResolver [arrowhead = "empty"];
}
