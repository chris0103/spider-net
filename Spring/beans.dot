	AbstractEnvironment -> ConfigurableEnvironment [arrowhead = "empty"];
	ConfigurableEnvironment -> Environment;
	XmlBeanDefinitionReader -> AbstractBeanDefinitionReader;
	XmlBeanDefinitionReader:f1 -> ResourceEntityResolver [arrowhead = "vee"];
	ResourceEntityResolver -> DelegatingEntityResolver;
	DelegatingEntityResolver -> EntityResolver [arrowhead = "odot"];
	XmlBeanDefinitionReader:f2 -> DefaultBeanDefinitionDocumentReader [arrowhead = "vee"];
	DefaultBeanDefinitionDocumentReader -> BeanDefinitionDocumentReader [arrowhead = "empty"];
	DefaultBeanDefinitionDocumentReader:f1 -> BeanDefinitionParserDelegate [arrowhead = "vee"];
	
	/** bean definition **/
	BeanDefinitionParserDelegate:f2 -> BeanDefinitionHolder [arrowhead = "vee"];
	BeanDefinitionHolder:f1 -> GenericBeanDefinition [arrowhead = "vee"];
	GenericBeanDefinition -> AbstractBeanDefinition;
	AbstractBeanDefinition -> BeanDefinition [arrowhead = "empty"];
	
	/** bean name generator **/
	BeanNameGenerator:f2 -> BeanDefinition [arrowhead = "vee"];
	BeanNameGenerator:f2 -> BeanDefinitionRegistry [arrowhead = "vee"];
	
	/** property configurer **/
	PropertyResourceConfigurer -> PropertiesLoaderSupport;
	PlaceholderConfigurerSupport -> PropertyResourceConfigurer;
