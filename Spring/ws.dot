	subgraph cluster77 {
		label = "web";
		style = filled;
		color = grey90;
		AbstractJaxWsServiceExporter [label = "{<f0>AbstractJaxWsServiceExporter||}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		HessianClientInterceptor [label = "{<f0>HessianClientInterceptor|<f1>+ hessianProxy : Object\l+ proxyFactory : HessianProxyFactory\l|<f2>+ createHessianProxy(HessianProxyFactory) : Object\l+ prepare() : void\l}", style = "rounded, filled", fillcolor = "springgreen"];
		HessianExporter [label = "{<f0>HessianExporter|<f1>+ remoteResolver : HessianRemoteResolver\l+ skeleton : HessianSkeleton\l|<f2>+ doInvoke(HessianSkeleton, InputStream, OutputStream) : void\l+ invoke(InputStream, outputStream) : void\l+ prepare() : void\l}", style = "rounded, filled", fillcolor = "springgreen"];
		HessianServiceExporter [label = "{<f0>HessianServiceExporter||}", style = "rounded, filled", fillcolor = "springgreen"];
		HessianProxyFactoryBean [label = "{<f0>HessianProxyFactoryBean|<f1>+ serviceProxy : Object\l|}", style = "rounded, filled", fillcolor = "springgreen"];
		HttpInvokerClientConfiguration [label = "{<f0>HttpInvokerClientConfiguration|<f2>+ getCodebaseUrl() : String\l+ getServiceUrl() : String\l}", style = "rounded, filled", fillcolor = "mediumpurple1"];
		HttpInvokerClientInterceptor [label = "{<f0>HttpInvokerClientInterceptor|<f1>+ codebaseUrl : String\l+ httpInvokerRequestExecutor : HttpInvokerRequestExecutor\l|<f2>+ executeRequest(RemoteInvocation) : RemoteInvocationResult\l+ executeRequest(RemoteInvocation, MethodInvocation) : RemoteInvocationResult\l}", style = "rounded, filled", fillcolor = "springgreen"];
		HttpInvokerProxyFactoryBean [label = "{<f0>HttpInvokerProxyFactoryBean|<f1>+ serviceProxy : Object\l|}", style = "rounded, filled", fillcolor = "springgreen"];
		HttpInvokerServiceExporter [label = "{<f0>HttpInvokerServiceExporter||}", style = "rounded, filled", fillcolor = "springgreen"];
		HttpRequestHandler [label = "{<f0>HttpRequestHandler|<f2>+ handleRequest(HttpServletRequest, HttpServletResponse) : void\l}", style = "rounded, filled", fillcolor = "mediumpurple1"];
		JaxWsPortClientInterceptor [label = "{<f0>JaxWsPortClientInterceptor|<f1>+ portName : String\l+ serviceInterface : Class&lt;?&gt;\l|<f2>+ doInvoke(MethodInvocation) : Object\l+ doInvoke(MethodInvocation, Object) : Object\l+ prepare() : void\l}", style = "rounded, filled", fillcolor = "springgreen"];
		JaxWsPortProxyFactoryBean [label = "{<f0>JaxWsPortProxyFactoryBean|<f1>+ serviceProxy : Object\l|}", style = "rounded, filled", fillcolor = "springgreen"];
		LocalJaxWsServiceFactory [label = "{<f0>LocalJaxWsServiceFactory|<f1>+ namespaceUri : String\l+ serviceName : String\l+ wsdlDocumentUrl : URL\l|<f2>+ createJaxWsService() : Service\l}", style = "rounded, filled", fillcolor = "springgreen"];
		SimpleJaxWsServiceExporter [label = "{<f0>SimpleJaxWsServiceExporter|<f1>+ baseAddress : String\l|<f2>+ calculateEndpointAddress(Endpoint, String) : String\l}", style = "rounded, filled", fillcolor = "springgreen"];
	}	

	subgraph cluster81 {
		label = "webmvc";
		style = filled;
		color = grey90;
	}
	
	subgraph cluster91 {
		label = "ws-core";
