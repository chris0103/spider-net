digraph name {
	rankdir = BT;
    fontname = "Verdana";
    fontsize = 8;
    node [fontname = "Verdana", fontsize = 8, shape = "record"];
    edge [fontname = "Verdana", fontsize = 8];
	
	subgraph cluster13 {
		label = "beans";
		style = filled;
		color = grey90;
		FactoryBean [label = "{<f0>FactoryBean&lt;T&gt;|<f2>+ getObject() : T\l+ getObjectType() : Class&lt;?&gt;\l+ isSingleton() : boolean\l}", style = "rounded, filled", fillcolor = "mediumpurple1"];
	}

	subgraph cluster18 {
		label = "context";
		style = filled;
		color = grey90;
		RemoteAccessor [label = "{<f0>RemoteAccessor|<f1>+ serviceInterface : Class&lt;?&gt;\l|}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		RemoteExporter [label = "{<f0>RemoteExporter|<f1>+ registerTraceInterceptor : Boolean\l+ interceptors : Object[]\l+ service : Object\l+ serviceInterface : Class&lt;?&gt;\l|}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		RemoteInvocationBasedAccessor [label = "{<f0>RemoteInvocationBasedAccessor|<f1>+ remoteInvocationFactory : RemoteInvocationFactory\l|<f2>+ recreateRemoteInvocationResult(RemoteInvocationResult) : Object\l}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		RemoteInvocationBasedExporter [label = "{<f0>RemoteInvocationBasedExporter|<f1>+ remoteInvocationExecutor : RemoteInvocationExecutor\l|<f2>+ invoke(RemoteInvocation, Object) : Object\l+ invokeAndCreateResult(RemoteInvocation, Object) : RemoteInvocationResult\l}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		RemoteInvocationSerializingExporter [label = "{<f0>RemoteInvocationSerializingExporter|<f1>+ proxy : Object\l|<f2>+ createObjectInputStream(InputStream) : ObjectInputStream\l+ createObjectOutputStream(OutputStream) : ObjectOutputStream\l+ doReadRemoteInvocation(ObjectInputStream) : RemoteInvocation\l+ doWriteRemoteInvocationResult(RemoteInvocationResult, ObjectOutputStream) : void\l+ prepare() : void\l}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		RemotingSupport [label = "{<f0>RemotingSupport||}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		RmiBasedExporter [label = "{<f0>RmiBasedExporter||<f2>+ getObjectToExport() : Remote\l&#186; invoke(RemoteInvocation, Object) : Object\l}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
		RmiClientInterceptor [label = "{<f0>RmiClientInterceptor|<f1>+ registryClientSocketFactory : RMIClientSocketFactory\l|<f2>+ doInvoke(MethodInvocation, Remote) : Object\l+ doInvoke(MethodInvocation, RmiInvocationHandler) : Object\l+ getStub() : Remote\l+ lookupStub() : Remote\l+ prepare() : void\l}", style = "rounded, filled", fillcolor = "springgreen"];
		RmiProxyFactoryBean [label = "{<f0>RmiProxyFactoryBean|<f1>+ serviceProxy : Object\l|}", style = "rounded, filled", fillcolor = "springgreen"];
		RmiServiceExporter [label = "{<f0>RmiServiceExporter|<f1>+ registryHost : String\l+ registryPort : int\l+ serviceName : String\l+ servicePort : int\l|<f2>+ prepare() : void\l}", style = "rounded, filled", fillcolor = "springgreen"];
		UrlBasedRemoteAccessor [label = "{<f0>UrlBasedRemoteAccessor|<f1>+ serviceUrl : String\l|}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
	}

	subgraph cluster23 {
		label = "context-support";
		style = filled;
		color = grey90;
	}
	
	subgraph cluster28 {
		label = "core";
		style = filled;
		color = grey90;
	}

	subgraph cluster54 {
		label = "oxm";
		style = filled;
