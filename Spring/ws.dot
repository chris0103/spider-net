	// interface_minor [shape = "plaintext", label = "Interface_minor"];
	// interface [label = "{<f0>Interface|<f2>+ method() : return_type\l}", style = "rounded, filled", fillcolor = "mediumpurple1"];
	// abstract_class [label = "{<f0>Abstract_Class|<f1>+ field1 : type\l+ filed2 : type\l|<f2>&#170; abstract_method() : return_type\l&#537; static_method() : return_type\l+ method() : return_type\l}", style = "rounded, filled, dashed", fillcolor = "springgreen"];
	// class [label = "{<f0>Class|<f1>+ field1 : type\l+ filed2 : type\l|<f2>+ method() : return_type\l&#537; static_method() : return_type\l&#186; overriden_method() : return_type\l}", style = "rounded, filled", fillcolor = "springgreen"];

	
	// Implementation -> Interface [arrowhead = "empty"];
	// Subclass -> Class;	
	// Referer -> Referee [arrowhead = "vee"];
	// Implementation -> InterfaceMinor [arrowhead = "odot"];

	/** various web service exporters **/
	RmiServiceExporter -> RmiBasedExporter;
	RmiBasedExporter -> RemoteInvocationBasedExporter;
	RemoteInvocationBasedExporter -> RemoteExporter;
	RemoteExporter -> RemotingSupport;
	HessianServiceExporter -> HttpRequestHandler [arrowhead = "empty"];
	HessianServiceExporter -> HessianExporter;
	HessianExporter -> RemoteExporter;
	HttpInvokerServiceExporter -> HttpRequestHandler [arrowhead = "empty"];
	HttpInvokerServiceExporter -> RemoteInvocationSerializingExporter;
	RemoteInvocationSerializingExporter -> RemoteInvocationBasedExporter;
	SimpleJaxWsServiceExporter -> AbstractJaxWsServiceExporter;
	
	/** various web service proxies for client **/
	RmiProxyFactoryBean -> FactoryBean [arrowhead = "empty", label = "T = Object"];
	RmiProxyFactoryBean -> RmiClientInterceptor;
	RmiClientInterceptor -> RemoteInvocationBasedAccessor;
	RemoteInvocationBasedAccessor -> UrlBasedRemoteAccessor;
	UrlBasedRemoteAccessor -> RemoteAccessor;
	RemoteAccessor -> RemotingSupport;
	HessianProxyFactoryBean -> FactoryBean [arrowhead = "empty", label = "T = Object"];
	HessianProxyFactoryBean -> HessianClientInterceptor;
	HessianClientInterceptor -> UrlBasedRemoteAccessor;
	HttpInvokerProxyFactoryBean -> HttpInvokerClientInterceptor;
	HttpInvokerClientInterceptor -> HttpInvokerClientConfiguration [arrowhead = "empty"];
	HttpInvokerClientInterceptor -> RemoteInvocationBasedAccessor;
	JaxWsPortProxyFactoryBean -> FactoryBean [arrowhead = "empty", label = "T = Object"];
	JaxWsPortProxyFactoryBean -> JaxWsPortClientInterceptor;
	JaxWsPortClientInterceptor -> LocalJaxWsServiceFactory;
}
